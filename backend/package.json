{
  "name": "attendance-backend",
  "version": "1.0.0",
  "description": "Backend for Smart Attendance Management System",
  "main": "server.js",
  "scripts": {
    "start": "npx prisma generate && node server.js",
    "dev": "nodemon server.js",
    "seed": "node prisma/seed.js",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
